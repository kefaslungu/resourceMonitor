#: addon\globalPlugins\resourceMonitor\__init__.py:47
msgid "No authentication (Open)"
msgstr "Без автентифікації (Відкрито)"

#: addon\globalPlugins\resourceMonitor\__init__.py:72
#, python-brace-format
msgid "Connected to {}"
msgstr "Підключено до {}"

#: addon\globalPlugins\resourceMonitor\__init__.py:82
#, python-brace-format
msgid "Disconnected from {}"
msgstr "Відключено від {}"

#: addon\globalPlugins\resourceMonitor\__init__.py:87
msgid "A wireless device has been enabled"
msgstr "Бездротовий пристрій увімкнено"

#: addon\globalPlugins\resourceMonitor\__init__.py:93
msgid "A wireless device has been disabled"
msgstr "Бездротовий пристрій вимкнено"

#. Translators: Message reported when there is no battery on the system,
#. mostly laptops with battery pack removed and running on AC power.
#: addon\globalPlugins\resourceMonitor\__init__.py:216
msgid "This computer does not have a battery connected."
msgstr "До цього комп’ютера не підключено акумулятор."

#. Translators: message presented when AC is connected and battery is charging,
#. also show current battery percentage.
#: addon\globalPlugins\resourceMonitor\__init__.py:222
#, python-brace-format
msgid "{percent}%, battery charging."
msgstr "{percent}%, акумулятор заряджається."

#. Translators: message presented when computer is running on battery power,
#. showing percentage remaining yet battery time is unknown.
#: addon\globalPlugins\resourceMonitor\__init__.py:228
#, python-brace-format
msgid "{percent}% battery remaining, battery time unknown."
msgstr ""
"Залишилося {percent}% заряду акумулятора, час роботи акумулятора невідомий."

#. Translators: battery and system uptime in hours.
#. Translators: system uptime in hours.
#: addon\globalPlugins\resourceMonitor\__init__.py:242
#: addon\globalPlugins\resourceMonitor\__init__.py:553
#, python-brace-format
msgid "{hours:d} hour"
msgid_plural "{hours:d} hours"
msgstr[0] "{hours:d} година"
msgstr[1] "{hours:d} години"
msgstr[2] "{hours:d} годин"

#. Translators: battery and system uptime in minutes.
#. Translators: system uptime in minutes.
#: addon\globalPlugins\resourceMonitor\__init__.py:247
#: addon\globalPlugins\resourceMonitor\__init__.py:557
#, python-brace-format
msgid "{minutes:d} minute"
msgid_plural "{minutes:d} minutes"
msgstr[0] "{minutes:d} хвилина"
msgstr[1] "{minutes:d} хвилини"
msgstr[2] "{minutes:d} хвилин"

#. Translators: message presented when computer is running on battery power,
#. showing percentage remaining and estimated remaining time.
#: addon\globalPlugins\resourceMonitor\__init__.py:255
#, python-brace-format
msgid "{percent}% battery remaining, about {time}."
msgstr "Залишилося {percent}% заряду акумулятора, приблизно {time}."

#. Translators: Message reported when battery level is low.
#: addon\globalPlugins\resourceMonitor\__init__.py:259
msgid " Warning: low battery."
msgstr " Попередження: низький заряд акумулятора."

#. Translators: Message reported when battery level is critical.
#: addon\globalPlugins\resourceMonitor\__init__.py:262
msgid " Warning: critically low battery."
msgstr " Попередження: заряд акумулятора критично низький."

#. Translators: Presents Windows version (example output: "Windows 10 22H2 (AMD64) build 19045.5247").
#: addon\globalPlugins\resourceMonitor\__init__.py:283
#, python-brace-format
msgid "{winVersion} ({cpuBit}) build {build}"
msgstr "{winVersion} ({cpuBit}) збірка {build}"

#. Translators: The gestures category for this add-on in input gestures dialog (2013.3 or later).
#. Add-on summary/title, usually the user visible name of the add-on
#. Translators: Summary/title for this add-on
#. to be shown on installation and add-on information found in add-on store
#: addon\globalPlugins\resourceMonitor\__init__.py:291 buildVars.py:21
msgid "Resource Monitor"
msgstr "Монітор ресурсів"

#: addon\globalPlugins\resourceMonitor\__init__.py:334
#, python-brace-format
msgid "GPU {gpuNumber}: usage {usage}%, temp {temperature}°C."
msgstr ""
"Графічний процесор {gpuNumber}: використання {usage}%, температура "
"{temperature} °C."

#: addon\globalPlugins\resourceMonitor\__init__.py:344
msgid "No GPU information available."
msgstr "Інформація про графічний процесор відсутня."

#: addon\globalPlugins\resourceMonitor\__init__.py:346
msgid "Unable to get GPU information."
msgstr "Не вдалося отримати інформацію про графічний процесор."

#: addon\globalPlugins\resourceMonitor\__init__.py:347
msgid "No GPU data available."
msgstr "Дані про графічний процесор відсутні."

#. Translators: Input help message about battery info command in Resource Monitor.
#: addon\globalPlugins\resourceMonitor\__init__.py:352
msgid ""
"Presents battery percentage, charging status, remaining time (if not "
"charging), and a warning if the battery is low or critical."
msgstr ""
"Повідомляє про відсоток заряду акумулятора, статус заряджання, час, що "
"залишився (якщо акумулятор не заряджається) і попередження про низький та "
"критично низький заряд акумулятора."

#: addon\globalPlugins\resourceMonitor\__init__.py:368
msgid ""
"Presents the used and total space of the static and removable drives on this "
"computer."
msgstr ""
"Надає інформацію про зайнятий та повний об'єм статичних та переносних "
"дисків, підключених до комп'ютера."

#. Translators: Shows drive letter, type of drive (fixed or removable),
#. used capacity and total capacity of a drive
#. (example: C drive, ntfs; 40 GB of 100 GB used (40%).
#: addon\globalPlugins\resourceMonitor\__init__.py:387
#, python-brace-format
msgid ""
"{driveName} ({driveType} drive): {usedSpace} of {totalSpace} used {percent}%."
msgstr ""
"{driveName} ({driveType} диск): {usedSpace} із {totalSpace} використано "
"{percent}%."

#. Translators: Input help mode message about processor info command in Resource Monitor.
#: addon\globalPlugins\resourceMonitor\__init__.py:402
msgid "Presents the average processor load and the load of each core."
msgstr ""
"Надає інформацію про середню завантаженість процесора і про завантаженість "
"кожного ядра."

#. Translators: Shows average load of CPU cores (example: core 1, 50%).
#: addon\globalPlugins\resourceMonitor\__init__.py:412
#, python-brace-format
msgid "Core {coreNumber}: {corePercent}%"
msgstr "Ядро {coreNumber}: {corePercent}%"

#. Translators: Shows average load of the processor on single-core systems.
#: addon\globalPlugins\resourceMonitor\__init__.py:419
#, python-brace-format
msgid "Average CPU load {avgLoad}%."
msgstr "Середня завантаженість процесора {avgLoad}%."

#. Translators: Shows average load of the processor and the load for each core on multi-core systems.
#: addon\globalPlugins\resourceMonitor\__init__.py:422
#, python-brace-format
msgid "Average CPU load {avgLoad}%, {cores}."
msgstr "Середня завантаженість процесора {avgLoad}%, {cores}."

#. Translators: Input help mode message about memory info command in Resource Monitor.
#: addon\globalPlugins\resourceMonitor\__init__.py:432
msgid "Presents the used and total space for both physical and virtual ram."
msgstr ""
"Надає інформацію про зайнятий та повний об’єм як фізичної, так і віртуальної "
"пам’яті."

#. Translators: Shows RAM (physical memory) usage.
#: addon\globalPlugins\resourceMonitor\__init__.py:440
#, python-brace-format
msgid "Physical: {physicalUsed} of {physicalTotal} used ({physicalPercent}%). "
msgstr ""
"Фізична пам'ять: {physicalUsed} із {physicalTotal} використовується "
"({physicalPercent}%). "

#. Translators: Shows virtual memory usage.
#: addon\globalPlugins\resourceMonitor\__init__.py:448
#, python-brace-format
msgid "Virtual: {virtualUsed} of {virtualTotal} used ({virtualPercent}%)."
msgstr ""
"Віртуальна пам’ять: {virtualUsed} із {virtualTotal} використовується "
"({virtualPercent}%)."

#. Translators: Input help mode message about Windows version command in Resource Monitor.
#: addon\globalPlugins\resourceMonitor\__init__.py:460
msgid "Announces the version of Windows you are using."
msgstr "Повідомляє про версію Windows, яку ви використовуєте."

#. Translators: Input help mode message about obtaining the ssid of the wireless network,
#. and the strength of the network.
#: addon\globalPlugins\resourceMonitor\__init__.py:475
msgid "Announces the system's wireless network ssid name, and its strength."
msgstr "Повідомляє ім'я ssid бездротової мережі системи та її потужність."

#. Translators: Input help mode message about GPU usage and temperature command.
#: addon\globalPlugins\resourceMonitor\__init__.py:488
msgid "Announces GPU usage and temperature."
msgstr "Повідомляє про використання та температуру графічного процесора."

#. Translators: Message reported when the GPU command fails unexpectedly.
#: addon\globalPlugins\resourceMonitor\__init__.py:500
msgid "Failed to get GPU information."
msgstr "Не вдалося отримати інформацію про графічний процесор."

#: addon\globalPlugins\resourceMonitor\__init__.py:504
#: addon\globalPlugins\resourceMonitor\__init__.py:511
msgid "No wireless devices"
msgstr "Немає бездротових пристроїв"

#: addon\globalPlugins\resourceMonitor\__init__.py:515
msgid "No wireless connections"
msgstr "Немає бездротових з'єднань"

#: addon\globalPlugins\resourceMonitor\__init__.py:528
#, python-brace-format
msgid "Connected wireless network: {}. Signal strength: {}%. Security type: {}"
msgstr "Підключено бездротову мережу: {}. Рівень сигналу: {}%. Тип захисту: {}"

#. Translators: system uptime in days.
#: addon\globalPlugins\resourceMonitor\__init__.py:549
#, python-brace-format
msgid "{days:d} day"
msgid_plural "{days:d} days"
msgstr[0] "{days:d} день"
msgstr[1] "{days:d} дні"
msgstr[2] "{days:d} днів"

#. Translators: system uptime in seconds.
#: addon\globalPlugins\resourceMonitor\__init__.py:561
#, python-brace-format
msgid "{seconds:d} second"
msgid_plural "{seconds:d} seconds"
msgstr[0] "{seconds:d} секунда"
msgstr[1] "{seconds:d} секунди"
msgstr[2] "{seconds:d} секунд"

#. Translators: Input help mode message about obtaining the system's uptime
#: addon\globalPlugins\resourceMonitor\__init__.py:567
msgid "Announces the system's uptime."
msgstr "Повідомляє час безперервної роботи системи."

#. Translators: Obtaining uptime failed
#: addon\globalPlugins\resourceMonitor\__init__.py:580
msgid "Failed to get the system's uptime."
msgstr "Невдалося отримати інформацію про безперервний час роботи системи."

#. Translators: Input help mode message about overall system resource info command in Resource Monitor
#: addon\globalPlugins\resourceMonitor\__init__.py:584
msgid ""
"Presents used ram, average processor load, and battery info if available."
msgstr ""
"Надає інформацію про використання оперативної пам'яті, середню "
"завантаженість процесора та акумулятор, якщо він є."

#: addon\globalPlugins\resourceMonitor\__init__.py:592
#, python-brace-format
msgid "{ramPercent}% RAM used, CPU at {cpuPercent}%."
msgstr ""
"Використано {ramPercent}% оперативної пам’яті, процесор завантажений на "
"{cpuPercent}%."

#. Add-on description
#. Translators: Long description to be shown for this add-on on add-on information from add-on store
#: buildVars.py:24
msgid ""
"A handy resource monitor to report CPU load, memory usage, battery, disk "
"usage status and more."
msgstr ""
"Зручний монітор ресурсів повідомляє про завантаженість процесора, "
"використання оперативної пам'яті, статус акумулятора і дискового простору, "
"та іншу інформацію."

#. Brief changelog for this version
#. Translators: what's new content for the add-on version to be shown in the add-on store
#: buildVars.py:29
msgid ""
"* Added an unassigned command to announce GPU (graphics processing unit) "
"information (contributed by kevinderome)."
msgstr ""
"* Додано непризначену команду для оголошення інформації про GPU (графічний "
"процесор) (надано kevinderome)."
