#: addon\globalPlugins\resourceMonitor\__init__.py:49
msgid "No authentication (Open)"
msgstr "Kimlik doğrulama yok (Açık)"

#: addon\globalPlugins\resourceMonitor\__init__.py:74
#, python-brace-format
msgid "Connected to {}"
msgstr "{} ağına bağlanıldı"

#: addon\globalPlugins\resourceMonitor\__init__.py:84
#, python-brace-format
msgid "Disconnected from {}"
msgstr "{} ağ bağlantısı kesildi"

#: addon\globalPlugins\resourceMonitor\__init__.py:89
msgid "A wireless device has been enabled"
msgstr "Bir kablosuz cihaz etkinleştirildi"

#: addon\globalPlugins\resourceMonitor\__init__.py:95
msgid "A wireless device has been disabled"
msgstr "Bir kablosuz cihaz devre dışı bırakıldı"

#. Translators: Presents Windows version (example output: "Windows 10 22H2 (AMD64) build 19045.5247").
#: addon\globalPlugins\resourceMonitor\__init__.py:225
#, python-brace-format
msgid "{winVersion} ({cpuBit}) build {build}"
msgstr "{winVersion} ({cpuBit}) Yapı {build}"

#. Translators: The gestures category for this add-on in input gestures dialog (2013.3 or later).
#. Add-on summary/title, usually the user visible name of the add-on
#. Translators: Summary/title for this add-on
#. to be shown on installation and add-on information found in add-on store
#: addon\globalPlugins\resourceMonitor\__init__.py:233 buildVars.py:21
msgid "Resource Monitor"
msgstr "Kaynak İzleme"

#. Translators: Input help mode message about overall system resource info command in Resource Monitor
#: addon\globalPlugins\resourceMonitor\__init__.py:288
msgid "Presents used ram and average processor load."
msgstr "Kullanılan ram ve ortalama işlemci yükünü bildirir."

#: addon\globalPlugins\resourceMonitor\__init__.py:296
#, python-brace-format
msgid "{ramPercent}% RAM used, CPU at {cpuPercent}%."
msgstr "yüzde {ramPercent} RAM kullanılan, CPU:  %{cpuPercent}."

#: addon\globalPlugins\resourceMonitor\__init__.py:305
msgid "Presents the average processor load and the load of each core. If pressed twice, copies the information to the clipboard."
msgstr "Ortalama işlemci yükünü ve her çekirdeğin yükünü seslendirir. İki kez basıldığında bilgiler panoya kopyalanır."

#. Translators: Shows average load of CPU cores (example: core 1, 50%).
#: addon\globalPlugins\resourceMonitor\__init__.py:317
#, python-brace-format
msgid "Core {coreNumber}: {corePercent}%"
msgstr "Çekirdek {coreNumber}: yüzde {corePercent}"

#. Translators: Shows average load of the processor on single-core systems.
#: addon\globalPlugins\resourceMonitor\__init__.py:324
#, python-brace-format
msgid "{avgLoad}% CPU load."
msgstr "%{avgLoad} CPU yükü."

#. Translators: Shows average load of the processor and the load for each core on multi-core systems.
#: addon\globalPlugins\resourceMonitor\__init__.py:327
#, python-brace-format
msgid "{avgLoad}% average CPU load, {cores}."
msgstr "%{avgLoad} ortalama CPU yükü, YUO{cores}."

#: addon\globalPlugins\resourceMonitor\__init__.py:338
msgid "Presents the used and total space for both physical and virtual ram. If pressed twice, copies the information to the clipboard."
msgstr "Hem fiziksel hem de sanal ram için kullanılmakta olan ve toplam alanı seslendirir. İki kez basıldığında bilgiler panoya kopyalanır."

#. Translators: Shows RAM (physical memory) usage.
#: addon\globalPlugins\resourceMonitor\__init__.py:348
#, python-brace-format
msgid "Physical: {physicalUsed} of {physicalTotal} used ({physicalPercent}%). "
msgstr "Fiziksel: {physicalUsed} bölü {physicalTotal} kullanılıyor (%{physicalPercent}). "

#. Translators: Shows virtual memory usage.
#: addon\globalPlugins\resourceMonitor\__init__.py:356
#, python-brace-format
msgid "Virtual: {virtualUsed} of {virtualTotal} used ({virtualPercent}%)."
msgstr "Sanal: {virtualUsed} bölü {virtualTotal} kullanılıyor (%{virtualPercent})."

#: addon\globalPlugins\resourceMonitor\__init__.py:369
msgid "Presents the used and total space of the fixed (built-in) and removable drives on this computer. If pressed twice, copies the information to the clipboard."
msgstr "Bu bilgisayardaki sabit (yerleşik) ve çıkarılabilir sürücülerin kullanılmakta olan ve toplam alanını seslendirir. İki kez basıldığında bilgiler panoya kopyalanır."

#. Translators: Shows drive letter, type of drive (fixed or removable),
#. used capacity and total capacity of a drive
#. (example: C drive, ntfs; 40 GB of 100 GB used (40%).
#: addon\globalPlugins\resourceMonitor\__init__.py:389
#, python-brace-format
msgid "{driveName} ({driveType} drive): {usedSpace} of {totalSpace} used ({percent}%)."
msgstr "{driveName} ({driveType} sürücüsü): {totalSpace} alanın {usedSpace}’si kullanıldı ({percent}%)."

#: addon\globalPlugins\resourceMonitor\__init__.py:404
#: addon\globalPlugins\resourceMonitor\__init__.py:411
msgid "No wireless devices"
msgstr "Kablosuz cihaz yok"

#: addon\globalPlugins\resourceMonitor\__init__.py:415
msgid "No wireless connections"
msgstr "Kablosuz bağlantı yok"

#: addon\globalPlugins\resourceMonitor\__init__.py:428
#, python-brace-format
msgid "Connected to {}, signal strength: {}%, security type: {}"
msgstr "{} ile bağlı, sinyal gücü: %{}, güvenlik türü: {}"

#: addon\globalPlugins\resourceMonitor\__init__.py:443
msgid "Announces the system's wireless network name (SSID), connection strength, and security  protocol. If pressed twice, copies the information to the clipboard."
msgstr "Sistemin kablosuz ağ adını (SSID), bağlantı gücünü ve güvenlik protokolünü seslendirir. İki kez basıldığında bilgiler panoya kopyalanır."

#: addon\globalPlugins\resourceMonitor\__init__.py:459
msgid "Announces the version of Windows you are using. If pressed twice, copies the information to the clipboard."
msgstr "Kullanılmakta olan Windows sürümünü seslendirir. İki kez basıldığında bilgiler panoya kopyalanır."

#. Translators: system uptime in days.
#: addon\globalPlugins\resourceMonitor\__init__.py:483
#, python-brace-format
msgid "{days:d} day"
msgid_plural "{days:d} days"
msgstr[0] "{days:d} gün"
msgstr[1] "{days:d} gün"

#. Translators: system uptime in hours.
#: addon\globalPlugins\resourceMonitor\__init__.py:487
#, python-brace-format
msgid "{hours:d} hour"
msgid_plural "{hours:d} hours"
msgstr[0] "{hours:d} saat"
msgstr[1] "{hours:d} saat"

#. Translators: system uptime in minutes.
#: addon\globalPlugins\resourceMonitor\__init__.py:491
#, python-brace-format
msgid "{minutes:d} minute"
msgid_plural "{minutes:d} minutes"
msgstr[0] "{minutes:d} dakika"
msgstr[1] "{minutes:d} dakika"

#. Translators: system uptime in seconds.
#: addon\globalPlugins\resourceMonitor\__init__.py:495
#, python-brace-format
msgid "{seconds:d} second"
msgid_plural "{seconds:d} seconds"
msgstr[0] "{seconds:d} saniye"
msgstr[1] "{seconds:d} saniye"

#: addon\globalPlugins\resourceMonitor\__init__.py:502
msgid "Announces the system's uptime. If pressed twice, copies the information to the clipboard."
msgstr "Sistemin çalışma süresini seslendirir. İki kez basıldığında bilgiler panoya kopyalanır."

#. Translators: Obtaining uptime failed
#: addon\globalPlugins\resourceMonitor\__init__.py:517
msgid "Failed to get the system's uptime."
msgstr "Sistemin açık olduğu zaman bilgisi alınamadı."

#: addon\globalPlugins\resourceMonitor\__init__.py:533
#, python-brace-format
msgid "GPU {gpuNumber}: usage {usage}%, temp {temperature}°C."
msgstr "GPU {gpuNumber}: kullanım %{usage}, sıcaklık {temperature}°C."

#: addon\globalPlugins\resourceMonitor\__init__.py:543
msgid "No GPU information available."
msgstr "GPU bilgisi mevcut değil."

#: addon\globalPlugins\resourceMonitor\__init__.py:545
msgid "Unable to get GPU information."
msgstr "GPU bilgisi alınamıyor."

#: addon\globalPlugins\resourceMonitor\__init__.py:546
msgid "No GPU data available."
msgstr "GPU verisi yok."

#: addon\globalPlugins\resourceMonitor\__init__.py:551
msgid "Announces GPU usage and temperature. If pressed twice, copies the information to the clipboard."
msgstr "GPU kullanımını ve sıcaklığını seslendirir. İki kez basıldığında bilgiler panoya kopyalanır."

#. Translators: Message reported when the GPU command fails unexpectedly.
#: addon\globalPlugins\resourceMonitor\__init__.py:569
msgid "Failed to get GPU information."
msgstr "GPU bilgileri alınamadı."

#. Add-on description
#. Translators: Long description to be shown for this add-on on add-on information from add-on store
#: buildVars.py:24
msgid "A handy resource monitor to report CPU load, memory usage, battery, disk usage status and more."
msgstr "CPU yükü, hafıza kullanımı, pil ve disk kullanım durumunu takip etmek ve daha fazlası için pratik bir araç."

#. Brief changelog for this version
#. Translators: what's new content for the add-on version to be shown in the add-on store
#: buildVars.py:29
msgid "* Removed add-on changelog from add-on help (readme) file.\n"
"* Changed CPU load and wireless network status announcements to show average CPU load percentage first and made network status reporting less verbose, respectively.\n"
"* NVDA will no longer repeat wireless network status announcements when the add-on is reloaded without first restarting NVDA (Control+NVDA+F3).\n"
"* NVDA will no longer announce GPU information in secure screens due to how the feature works internally.\n"
"* Battery status anouncement command (NVDA+Shift+4) and announcing battery info as part of the overall resource usage information (NVDA+Shift+E) are deprecated and will be removed in a future add-on release (NVDA provides its own battery status command (NVDA+Shift+B))."
msgstr "* Eklenti değişiklik günlüğü, eklenti yardım (readme) dosyasından kaldırıldı.\n"
"* CPU yükü ve kablosuz ağ durumu bildirimlerinde, sırasıyla önce ortalama CPU yük yüzdesini gösterecek şekilde değişiklik yapıldı ve ağ durumu raporlaması daha özlü hale getirildi.\n"
"* NVDA, NVDA'yı yeniden başlatmadan eklenti yeniden yüklendiğinde artık kablosuz ağ durumu duyurularını tekrarlamayacak (Kontrol+NVDA+F3).\n"
"* NVDA, özelliğin dahili çalışma şekli nedeniyle artık GPU bilgilerini güvenli ekranlarda duyurmayacak.\n"
"* Pil durumu duyuru komutu (NVDA+Shift+4) ve genel kaynak kullanım bilgilerinin bir parçası olarak pil bilgisini duyuran komut (NVDA+Shift+E) kullanımdan kaldırılmıştır ve gelecekteki bir eklenti sürümünde kaldırılacaktır (NVDA, kendi pil durumu komutunu sağlar (NVDA+Shift+B))."

